<?xml version="1.0"?>
<robot name="banda_transportadora" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ===================================================================
       Includes: materiales (colores) y configuración de Gazebo/plugin
       =================================================================== -->
  <xacro:include filename="materials.xacro"/>
  <xacro:include filename="gazebo.xacro"/>

  <!-- ===================================================================
       Constantes de ángulos, para no repetir 3.14159... y 1.5707... a
       mano por todo el archivo
       =================================================================== -->
  <xacro:property name="PI" value="3.1415926535897932384626433"/>
  <xacro:property name="HALF_PI" value="1.570796326794896619231"/>

  <!-- ===================================================================
       base_footprint: link vacío (sin geometría/inercia) que marca el punto
       de apoyo en el suelo. Es el root real del URDF: al spawnear en
       Gazebo en z=0, este link queda a nivel del piso y body_link (junto
       con las patas de soporte) sube 0.728 m, evitando que el robot
       atraviese el suelo.
       =================================================================== -->
  <link name="base_footprint"/>

  <joint name="base_footprint_body_joint" type="fixed">
    <origin xyz="0.0 0.0 0.728" rpy="0.0 0.0 0.0"/>
    <parent link="base_footprint"/>
    <child link="body_link"/>
  </joint>

  <!-- ===================================================================
       body_link  (Color: aluminio pulido)
       =================================================================== -->
  <link name="body_link">
    <inertial>
      <origin xyz="-0.0 -7.427e-05 -0.019" rpy="0.0 0.0 0.0"/>
      <mass value="1.813"/>
      <inertia ixx="0.014" iyy="0.609" izz="0.622" ixy="-2.219e-5" iyz="-7.770e-6" ixz="-1.441e-5"/>
    </inertial>
    <visual name="body_link_visual">
      <origin xyz="0.0 0.0 0.0" rpy="0.0 -0.0 0.0"/>
      <geometry>
        <mesh filename="package://banda/meshes/body.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="aluminio_pulido"/>
    </visual>
    <collision name="body_link_collision">
      <origin xyz="0.0 0.0 0.0" rpy="0.0 -0.0 0.0"/>
      <geometry>
        <mesh filename="package://banda/meshes/body.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- ===================================================================
       belt_link  (Color: caucho). Sobre esta banda actúa el plugin
       de banda transportadora definido en gazebo.xacro
       =================================================================== -->
  <link name="belt_link">
    <inertial>
      <origin xyz="0.0 0.0 -0.020941019429685542" rpy="0.0 0.0 0.0"/>
      <mass value="0.488"/>
      <inertia ixx="0.002" iyy="0.088" izz="0.089" ixy="0.0" iyz="0.0" ixz="0"/>
    </inertial>
    <visual name="belt_link_visual">
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://banda/meshes/band.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="caucho"/>
    </visual>
    <collision name="belt_link_collision">
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://banda/meshes/band.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <joint name="body_belt_joint" type="fixed">
    <origin xyz="0.0 0.0 0.0" rpy="0.0 -0.0 0.0"/>
    <parent link="body_link"/>
    <child link="belt_link"/>
  </joint>

  <!-- ===================================================================
       belt_surface_link: cuerpo delgado e invisible, DINÁMICO, que se
       apoya justo sobre la superficie real de la banda (z=0.003 respecto
       a belt_link, el techo de band.stl). Unido a belt_link con un joint
       PRISMÁTICO llamado "belt_joint" (nombre exigido por
       ros2_conveyorbelt_plugin: busca ese nombre exacto con GetJoint()).
       El plugin le impone velocidad a este joint y, por fricción alta
       (mu1/mu2 en gazebo.xacro), arrastra lo que esté apoyado encima sin
       que la banda tenga que desplazarse de verdad: el joint tiene un
       recorrido mínimo (0 a 0.01 m) y el plugin reinicia la posición a 0
       apenas llega al límite (efecto "cinta sin fin").
       =================================================================== -->
  <link name="belt_surface_link">
    <!-- Inercia real de una caja de 1.4x0.17x0.02 m y 10 kg (fórmula
         estándar de caja rígida), NO un valor casi-cero "hack". Con masa
         alta e inercia rotacional casi nula (como en el modelo de
         referencia del plugin) cualquier torque de contacto -por ejemplo
         el impacto de la caja de prueba- produce una aceleración angular
         enorme y el joint diverge a NaN casi al instante. -->
    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <mass value="10.0"/>
      <inertia ixx="0.02442" iyy="1.63367" izz="1.65742" ixy="0.0" iyz="0.0" ixz="0.0"/>
    </inertial>
    <!-- Espesor real (2 cm), NO microscópico: una caja de 0.00001 m (como
         en el modelo de referencia del plugin) hace que cualquier objeto
         que caiga con algo de velocidad la atraviese en un solo paso de
         física ("tunneling"), porque ODE hace detección de colisión
         discreta, no continua. El origin en z=-espesor/2 deja la CARA
         SUPERIOR de la caja exactamente al ras de la superficie real y
         visible de la banda (z=0.003 en el frame de belt_link, heredado
         del joint) y la caja crece HACIA ABAJO, empotrada dentro de la
         malla real de belt_link (invisible ahí, sin problema: belt_link y
         belt_surface_link están unidos por un joint, así que Gazebo no
         chequea colisión entre ellos). Si creciera hacia arriba, los
         objetos quedarían flotando visiblemente encima de la banda real. -->
    <collision name="belt_surface_link_collision">
      <origin xyz="0.0 0.0 -0.01" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="1.4 0.17 0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="belt_joint" type="prismatic">
    <origin xyz="0.0 0.0 0.003" rpy="0.0 0.0 0.0"/>
    <parent link="belt_link"/>
    <child link="belt_surface_link"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.01" effort="1000" velocity="1.0"/>
  </joint>

  <!-- ===================================================================
       Macro de brazo (art1 -> iron_bar -> art2), reutilizada para el
       lado izquierdo y el lado derecho. Cambia únicamente el prefijo
       y los orígenes/orientaciones de sus 3 juntas.
       =================================================================== -->
  <xacro:macro name="brazo_banda"
               params="prefix xyz_b_a1 rpy_b_a1 xyz_a1_ib rpy_a1_ib xyz_ib_a2 rpy_ib_a2">

    <!-- Color: caucho -->
    <link name="${prefix}_art1_link">
      <inertial>
        <origin xyz="0.0 0.0 -0.00504654" rpy="0.0 0.0 0.0"/>
        <mass value="0.0188"/>
        <inertia ixx="4.667e-06" iyy="3.57e-06" izz="3.918e-06" ixy="0.0" iyz="1.548e-08" ixz="0"/>
      </inertial>
      <visual name="${prefix}_art1_link_visual">
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <geometry>
          <mesh filename="package://banda/meshes/art1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="caucho"/>
      </visual>
      <collision name="${prefix}_art1_link_collision">
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <geometry>
          <mesh filename="package://banda/meshes/art1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <!-- Color: aluminio pulido -->
    <link name="${prefix}_iron_bar_link">
      <inertial>
        <origin xyz="0.0 0.0 0.075" rpy="0.0 0.0 0.0"/>
        <mass value="0.046"/>
        <inertia ixx="8.513e-05" iyy="8.513e-05" izz="8.181e-07" ixy="0.0" iyz="0" ixz="0"/>
      </inertial>
      <visual name="${prefix}_iron_bar_link_visual">
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <geometry>
          <mesh filename="package://banda/meshes/iron_bar.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="aluminio_pulido"/>
      </visual>
      <collision name="${prefix}_iron_bar_link_collision">
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <geometry>
          <mesh filename="package://banda/meshes/iron_bar.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <!-- Color: caucho -->
    <link name="${prefix}_art2_link">
      <inertial>
        <origin xyz="6.166e-05 -6.166e-05 0.00" rpy="0.0 0.0 0.0"/>
        <mass value="0.012"/>
        <inertia ixx="2.973e-06" iyy="2.973e-06" izz="9.381e-07" ixy="0.0" iyz="-1.485e-08" ixz="-1.485e-08"/>
      </inertial>
      <visual name="${prefix}_art2_link_visual">
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <geometry>
          <mesh filename="package://banda/meshes/art2.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="caucho"/>
      </visual>
      <collision name="${prefix}_art2_link_collision">
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <geometry>
          <mesh filename="package://banda/meshes/art2.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <joint name="body_${prefix}_art1_joint" type="fixed">
      <origin xyz="${xyz_b_a1}" rpy="${rpy_b_a1}"/>
      <parent link="body_link"/>
      <child link="${prefix}_art1_link"/>
    </joint>

    <joint name="${prefix}_art1_${prefix}_iron_bar_joint" type="fixed">
      <origin xyz="${xyz_a1_ib}" rpy="${rpy_a1_ib}"/>
      <parent link="${prefix}_art1_link"/>
      <child link="${prefix}_iron_bar_link"/>
    </joint>

    <joint name="${prefix}_iron_bar_${prefix}_art2_joint" type="fixed">
      <origin xyz="${xyz_ib_a2}" rpy="${rpy_ib_a2}"/>
      <parent link="${prefix}_iron_bar_link"/>
      <child link="${prefix}_art2_link"/>
    </joint>

  </xacro:macro>

  <!-- Brazo izquierdo -->
  <xacro:brazo_banda
      prefix="left"
      xyz_b_a1="-0.0535 -0.135 -0.023"  rpy_b_a1="-${HALF_PI} ${HALF_PI} 0.0"
      xyz_a1_ib="0.06 0.0 -0.0095"      rpy_a1_ib="${PI} ${HALF_PI} 0.0"
      xyz_ib_a2="-0.00 0.0075 0.1395"   rpy_ib_a2="${HALF_PI} 0.0 ${PI}"/>

  <!-- Brazo derecho -->
  <xacro:brazo_banda
      prefix="right"
      xyz_b_a1="0.3465 -0.135 -0.023"   rpy_b_a1="-${HALF_PI} -${HALF_PI} 0.0"
      xyz_a1_ib="-0.06 0.0 -0.0095"     rpy_a1_ib="0.0 ${HALF_PI} 0.0"
      xyz_ib_a2="-0.00 -0.0075 0.1395"  rpy_ib_a2="-${HALF_PI} -${HALF_PI} 0.0"/>

  <!-- ===================================================================
       iron_bar2_link  (Color: aluminio pulido). Solo cuelga del brazo
       izquierdo (art2), tal como en el URDF original
       =================================================================== -->
  <link name="iron_bar2_link">
    <inertial>
      <origin xyz="0.0 0.0 -0.05362153" rpy="0.0 0.0 0.0"/>
      <mass value="0.383"/>
      <inertia ixx="0.001" iyy="0.013" izz="0.012" ixy="0.0" iyz="0.0" ixz="0.0"/>
    </inertial>
    <visual name="iron_bar2_link_visual">
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://banda/meshes/iron_bar2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="aluminio_pulido"/>
    </visual>
    <collision name="iron_bar2_link_collision">
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://banda/meshes/iron_bar2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <joint name="left_art2_iron_bar2_joint" type="fixed">
    <origin xyz="0.069 0.0 0.1925" rpy="${PI} -${HALF_PI} 0.0"/>
    <parent link="left_art2_link"/>
    <child link="iron_bar2_link"/>
  </joint>

  <!-- ===================================================================
       Soportes (Color: aluminio pulido)
       =================================================================== -->
  <!-- Colisión de las patas: caja primitiva (no la malla STL cóncava real,
       que solo se usa para el visual). Ahora que el robot completo es
       dinámico (ver gazebo.xacro), una malla cóncava en contacto directo
       con el plano del suelo es numéricamente inestable en ODE (el modelo
       tiembla/exploye). La caja aproxima el bounding box real de
       support_L.stl/support_R.stl (0.08 x 0.357 x 0.6824 m, centro en
       x=0 y=0 z=-0.2908) y da un contacto caja-plano estable. -->
  <xacro:property name="support_box_size" value="0.08 0.357 0.6824"/>
  <xacro:property name="support_box_origin_xyz" value="0.0 0.0 -0.2908"/>

  <link name="support_L_link">
    <inertial>
      <origin xyz="-2.658e-07 0.0 -0.23231271" rpy="0.0 0.0 0.0"/>
      <mass value="0.699"/>
      <inertia ixx="0.044" iyy="0.035" izz="0.01" ixy="0.0" iyz="0.0" ixz="4.682e-08"/>
    </inertial>
    <visual name="support_L_link_visual">
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://banda/meshes/support_L.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="aluminio_pulido"/>
    </visual>
    <collision name="support_L_link_collision">
      <origin xyz="${support_box_origin_xyz}" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="${support_box_size}"/>
      </geometry>
    </collision>
  </link>

  <link name="support_R_link">
    <inertial>
      <origin xyz="-2.658e-07 0.0 -0.23231271" rpy="0.0 0.0 0.0"/>
      <mass value="0.699"/>
      <inertia ixx="0.044" iyy="0.035" izz="0.01" ixy="0.0" iyz="8.086e-07" ixz="4.681e-08"/>
    </inertial>
    <visual name="support_R_link_visual">
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://banda/meshes/support_R.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="aluminio_pulido"/>
    </visual>
    <collision name="support_R_link_collision">
      <origin xyz="${support_box_origin_xyz}" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="${support_box_size}"/>
      </geometry>
    </collision>
  </link>

  <joint name="body_support_L_joint" type="fixed">
    <origin xyz="-0.53748922 0.00015728 -0.678" rpy="${PI} -0.0 0.0"/>
    <parent link="body_link"/>
    <child link="support_L_link"/>
  </joint>

  <joint name="body_support_R_joint" type="fixed">
    <origin xyz="0.53748922 -9.272E-05 -0.678" rpy="${PI} -0.0 0.0"/>
    <parent link="body_link"/>
    <child link="support_R_link"/>
  </joint>

</robot>
